# GemGate Configuration
GEMGATE_PORT=8760
GEMGATE_BIND=0.0.0.0
GEMGATE_ADMIN_SECRET=change-this-to-a-random-string

# Google Account (for auto-login.py)
GEMGATE_GOOGLE_EMAIL=your-google-account@gmail.com
GEMGATE_GOOGLE_PASS=your-google-password

# Optional: Second Google account for round-robin
# GEMGATE_GOOGLE_EMAIL_2=backup-account@gmail.com
# GEMGATE_GOOGLE_PASS_2=backup-password

# Optional: Global API key for legacy /api/* endpoints
# GEMGATE_API_KEY=

# Display (for headless server with Xvfb)
DISPLAY=:99
